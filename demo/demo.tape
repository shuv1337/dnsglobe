# vhs tape for the README demo — regenerate with `vhs demo/demo.tape`
Output demo/demo.gif

Set Shell "bash"
Set FontSize 13
Set Width 1400
Set Height 780
Set Padding 12
Set TypingSpeed 60ms

Hide
Type "clear"
Enter
Show

Type "dnsglobe 514.ax"
Sleep 800ms
Enter
# initial A-record round streams in, map dots go green
Sleep 7s

# switch to NS and re-query to check the nameservers
Tab
Tab
Tab
Tab
Sleep 1s
Enter
Sleep 7s
